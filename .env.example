# File mẫu biến môi trường — commit file này lên GitHub.
# Khi setup thực tế, copy file này thành .env rồi điền thông tin thật vào.
# cp .env.example .env
# ----------------------------------------------------------------------------
# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=192.168.56.10   # IP VM1 (nơi Redis chạy); dùng 127.0.0.1 nếu local
REDIS_PORT=6379
REDIS_PASSWORD=            # Để trống trong lab

# ── Node Identity ─────────────────────────────────────────────────────────────
NODE_ID=edge-node-1        # edge-node-1 hoặc edge-node-2
NODE_IP=192.168.56.10

# ── Honeypot (chỉ dùng trên VM1) ─────────────────────────────────────────────
HONEYPOT_SSH_PORT=2222
HONEYPOT_TELNET_PORT=2323
HONEYPOT_HTTP_PORT=8080
HONEYPOT_HIT_THRESHOLD=1   # Bao nhiêu lần hit thì mới report

# ── eBPF Map ──────────────────────────────────────────────────────────────────
# Đặt USE_REAL_EBPF=false khi chưa có XDP module (dùng MockEbpfMap)
# Đặt USE_REAL_EBPF=true sau khi xdp_filter.c đã compile và load thành công
USE_REAL_EBPF=false
EBPF_MAP_PIN_PATH=/sys/fs/bpf/xdp_blacklist
